rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    match /{document=**} {
      allow read, write: if false;
    }

  
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && 
             (isEmailAdmin(request.auth.token.get('email', '')) || (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin')); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }



    function isEmailAdmin(email) {
      return email != null && (
        email.lower().endsWith('@fusaexplor.com') || 
        email.lower().endsWith('@fusaexplorer.com') ||
        email.lower() == 'riascosmarlon66@gmail.com' || 
        email.lower() == 'mike.otavo15@gmail.com' ||
        email.lower() == 'mike.otavo@fusaexplor.com'
      );
    }

    function isValidUsuario(data) {
      return data.nombre is string && data.nombre.size() > 0
          && data.correo is string && data.correo.size() > 0
          && data.rol in ['usuario', 'admin'];
    }

    function isValidCategoria(data) {
      return data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 60
          && data.color is string && data.color.matches('^#[0-9a-fA-F]{6}$')
          && (data.keys().hasAll(['nombre', 'color']) && data.keys().size() >= 2);
    }

    function isValidLugar(data) {
      return data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 150
          && data.direccion is string && data.direccion.size() > 0 && data.direccion.size() <= 300
          && data.categoriaId is string && isValidId(data.categoriaId)
          && data.puntuacion is number && data.puntuacion >= 0 && data.puntuacion <= 5
          && (data.lat is number || !('lat' in data))
          && (data.lng is number || !('lng' in data))
          && (data.imagenes is list || !('imagenes' in data));
    }

    function isValidComentario(data) {
      return data.usuarioId == request.auth.uid
          && data.puntuacion is number && data.puntuacion >= 0 && data.puntuacion <= 5
          && data.texto is string && data.texto.size() <= 300
          && (data.esPrivado is bool || !('esPrivado' in data));
    }

    function isValidReporte(data) {
      return data.tipo in ["trafico", "policia", "derrumbe", "semaforo", "desvio", "accidente"]
          && data.lat is number
          && data.lng is number
          && data.creadorId == request.auth.uid;
    }


    
    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && (
        (incoming().rol == 'usuario') || 
        (incoming().rol == 'admin' && (isEmailAdmin(incoming().correo) || isEmailAdmin(request.auth.token.get('email', ''))))
      );
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['nombre', 'avatar', 'rol', 'createdAt']) && (
          !incoming().diff(existing()).affectedKeys().hasAny(['rol']) || 
          isEmailAdmin(incoming().get('correo', existing().get('correo', ''))) ||
          isAdmin() ||
          isEmailAdmin(request.auth.token.get('email', ''))
        )
      )) || isAdmin();
    }


    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCategoria(incoming());
    }

  
    match /lugares/{lugarId} {
      allow read: if true;
      allow create: if (isAdmin() || isEmailAdmin(request.auth.token.get('email', ''))) 
                     && isValidLugar(incoming()) 
                     && incoming().propietarioId == request.auth.uid
                     && incoming().createdAt == request.time;
      allow update: if (isAdmin() || isEmailAdmin(request.auth.token.get('email', ''))) 
                     && isValidLugar(incoming()) 
                     && (incoming().propietarioId == existing().propietarioId || isAdmin())
                     && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }


    match /{path=**}/comentarios/{comentarioId} {
      allow read: if true;
    }
    match /lugares/{lugarId}/comentarios/{comentarioId} {
      allow create: if isSignedIn() && isValidComentario(incoming())
                     && incoming().createdAt == request.time
                     && exists(/databases/$(database)/documents/lugares/$(lugarId));
      allow update, delete: if isAdmin();
    }

  
    match /reportes/{reporteId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReporte(incoming())
                     && incoming().createdAt == request.time;
      allow update: if isSignedIn() 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])
                     && incoming().likes is number;
      allow delete: if isAdmin() || (isSignedIn() && existing().creadorId == request.auth.uid);
    }
  }
}
